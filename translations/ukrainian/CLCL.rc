IDR_MENU_VIEWER MENU
BEGIN
    POPUP "Файл"
    BEGIN
        MENUITEM "Новий елемент...\tCtrl+N",    ID_MENUITEM_NEW_ITEM
        MENUITEM "Зберегти як...\tCtrl+S",      ID_MENUITEM_DATA_SAVE
        MENUITEM SEPARATOR
        MENUITEM "Зберегти стан\tSCtrl+S",      ID_MENUITEM_SAVE
        MENUITEM SEPARATOR
        MENUITEM "Імпорт...",                   ID_MENUITEM_IMPORT
        MENUITEM "Експорт...",                  ID_MENUITEM_EXPORT
        MENUITEM SEPARATOR
        MENUITEM "Спостереження за буфером",    ID_MENUITEM_WATCH
        MENUITEM SEPARATOR
        MENUITEM "Закрити вікно",               ID_MENUITEM_CLOSE
        MENUITEM "Вихід",                       ID_MENUITEM_EXIT
    END
    POPUP "Правка"
    BEGIN
        MENUITEM "Відправити в буфер обміну\tCtrl+C", ID_MENUITEM_CLIPBOARD
        MENUITEM "Вставити з буфера\tCtrl+V",   ID_MENUITEM_PASTE
        MENUITEM "Додати до шаблону...\tCtrl+R", ID_MENUITEM_REGIST_ADD
        MENUITEM SEPARATOR
        MENUITEM "Перемістити вгору\tAlt+Up",   ID_MENUITEM_UP
        MENUITEM "Перемістити вниз\tAlt+Down",  ID_MENUITEM_DOWN
        MENUITEM SEPARATOR
        MENUITEM "Видалити",                    ID_MENUITEM_DELETE
        MENUITEM SEPARATOR
        MENUITEM "Вибрати все\tCtrl+A",         ID_MENUITEM_SELECT_ALL
    END
    POPUP "Вид"
    BEGIN
        MENUITEM "Панель інструментів",         ID_MENUITEM_SHOW_TOOLBAR
        MENUITEM "Рядок стану",                 ID_MENUITEM_SHOW_STATUSBAR
        MENUITEM SEPARATOR
        MENUITEM "Формат",                      ID_MENUITEM_SHOW_FORMAT
        MENUITEM "Дамп",                        ID_MENUITEM_SHOW_BIN
        MENUITEM SEPARATOR
        MENUITEM "Параметри...",                ID_MENUITEM_OPTION
    END
    POPUP "Інструменти"
    BEGIN
        MENUITEM "Налаштування інструментів...", ID_MENUITEM_TOOL_SET
        MENUITEM SEPARATOR
    END
    POPUP "Довідка"
    BEGIN
        MENUITEM "Довідка",                     ID_MENUITEM_HELP
        MENUITEM "Про програму...",             ID_MENUITEM_ABOUT
    END
END



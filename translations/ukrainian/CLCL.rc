        MENUITEM "Зберегти як...\tCtrl+S",      ID_MENUITEM_DATA_SAVE
        MENUITEM SEPARATOR
        MENUITEM "Видалити",                    ID_MENUITEM_DELETE
    END
    POPUP "Шаблон(TV)"
    BEGIN

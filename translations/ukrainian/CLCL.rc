IDR_MENU_POPUP MENU
BEGIN
    POPUP "Буфер обміну"
    BEGIN
        MENUITEM "Додати до шаблону...\tCtrl+R", ID_MENUITEM_REGIST_ADD
        MENUITEM "Зберегти як...\tCtrl+S",      ID_MENUITEM_DATA_SAVE
        MENUITEM "Показати як шістнадцятковий", ID_MENUITEM_SHOWBINARY
        MENUITEM SEPARATOR
        POPUP "Параметри"
        BEGIN
            MENUITEM "Формат...",                   ID_MENUITEM_SET_FORMAT
            MENUITEM "Фільтр...",                   ID_MENUITEM_SET_FILTER
        END
    END
    POPUP "Історія(TV)"
    BEGIN
        MENUITEM "Відправити в буфер обміну\tCtrl+C", ID_MENUITEM_CLIPBOARD
        MENUITEM "Вставити з буфера\tCtrl+V",   ID_MENUITEM_PASTE
        MENUITEM "Додати до шаблону...\tCtrl+R", ID_MENUITEM_REGIST_ADD
        MENUITEM "Показати як шістнадцятковий", ID_MENUITEM_SHOWBINARY
        MENUITEM "Інструменти",                 ID_MENUITEM_TOOL_MENU
        MENUITEM SEPARATOR
        MENUITEM "Перемістити вгору\tAlt+Up",   ID_MENUITEM_UP
        MENUITEM "Перемістити вниз\tAlt+Down",  ID_MENUITEM_DOWN
        MENUITEM SEPARATOR
        MENUITEM "Новий елемент...\tCtrl+N",    ID_MENUITEM_NEW_ITEM
        MENUITEM "Зберегти як...\tCtrl+S",      ID_MENUITEM_DATA_SAVE
        POPUP "Параметри"
        BEGIN
            MENUITEM "Формат...",                   ID_MENUITEM_SET_FORMAT
            MENUITEM "Фільтр...",                   ID_MENUITEM_SET_FILTER
        END
        MENUITEM SEPARATOR
        MENUITEM "Видалити",                    ID_MENUITEM_DELETE
    END

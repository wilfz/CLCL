IDD_DIALOG_TOOL_SET DIALOGEX 0, 0, 247, 263
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "插件编辑"
FONT 8, "MS Shell Dlg", 400, 0, 0x0
BEGIN
    LTEXT           "标题(&T):",IDC_STATIC,10,5,150,10
    EDITTEXT        IDC_EDIT_TITLE,10,15,190,13,ES_AUTOHSCROLL
    LTEXT           "(sep at - )",IDC_STATIC,204,18,43,10
    LTEXT           "&DLL:",IDC_STATIC,10,34,150,10
    EDITTEXT        IDC_EDIT_LIB_PATH,10,44,190,13,ES_AUTOHSCROLL
    PUSHBUTTON      "浏览(&B)...",IDC_BUTTON_FILE_SELECT,205,44,35,13
    LTEXT           "函数名称(&F):",IDC_STATIC,10,62,150,10
    EDITTEXT        IDC_EDIT_HEADER,10,72,190,13,ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "选择(&S)...",IDC_BUTTON_FUNC_SELECT,205,72,35,13
    LTEXT           "命令行(&m):",IDC_STATIC,10,88,150,10
    EDITTEXT        IDC_EDIT_CMD_LINE,10,98,230,13,ES_AUTOHSCROLL
    GROUPBOX        "调用类型",IDC_STATIC,10,115,230,125
    CONTROL         "动作菜单(&A)",IDC_CHECK_MENU,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,20,127,110,10
    CONTROL         "发送复制与粘贴(&P)",IDC_CHECK_COPY_PATE,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,30,139,100,10
    LTEXT           "热键(&k):",IDC_STATIC,135,125,50,10
    CONTROL         "",IDC_HOTKEY_TOOL,"select_key",WS_BORDER | WS_TABSTOP,135,135,95,13
    CONTROL         "查看器菜单(&V)",IDC_CHECK_VIEWER,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,20,153,165,10
    CONTROL         "打开查看器时(&o)",IDC_CHECK_VIEWER_OPEN,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,20,165,157,10
    CONTROL         "关闭查看器时(&l)",IDC_CHECK_VIEWER_CLOSE,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,20,177,157,10
    CONTROL         "数据添加到历史记录时(&i)",IDC_CHECK_HISTORY,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,20,189,165,10
    CONTROL         "数据发送到剪贴板时(&c)",IDC_CHECK_CLIPBOARD,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,20,201,165,10
    CONTROL         "程序启动时(&r)",IDC_CHECK_START,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,20,213,165,10
    CONTROL         "程序退出时(&x)",IDC_CHECK_END,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,20,225,165,10
    DEFPUSHBUTTON   "确定",IDOK,135,245,50,14
    PUSHBUTTON      "取消",IDCANCEL,191,245,50,14
    CONTROL         "旧",IDC_CHECK_OLD,"Button",BS_AUTOCHECKBOX | NOT WS_VISIBLE | WS_TABSTOP,10,245,45,10
END


